# Nestor - Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env — it is gitignored.
# ============================================================

# AWS Configuration
AWS_ACCOUNT_ID=<your-aws-account-id>
DEFAULT_AWS_REGION=us-east-1

# SageMaker Endpoint
SAGEMAKER_ENDPOINT=alex-embedding-endpoint

# Ingestion Pipeline
VECTOR_BUCKET=alex-vectors-<your-aws-account-id>
ALEX_API_ENDPOINT=https://<api-id>.execute-api.<region>.amazonaws.com/prod/ingest
ALEX_API_KEY=<your-api-gateway-key>

NESTOR_API_ENDPOINT=https://<api-id>.execute-api.<region>.amazonaws.com/prod/ingest
NESTOR_API_KEY=<your-api-gateway-key>

# OpenAI (only needed if using OpenAI models directly)
OPENAI_API_KEY=<your-openai-api-key>

# Database (Aurora) — get these from: cd terraform/5_database && terraform output
AURORA_CLUSTER_ARN=arn:aws:rds:<region>:<account-id>:cluster:alex-aurora-cluster
AURORA_SECRET_ARN=arn:aws:secretsmanager:<region>:<account-id>:secret:<secret-name>
AURORA_DATABASE=alex

# Bedrock
BEDROCK_MODEL_ID=openai.gpt-oss-120b-1:0
BEDROCK_REGION=us-east-1

# Polygon.io (market price data)
POLYGON_API_KEY=<your-polygon-api-key>
POLYGON_PLAN=free

# Clerk (authentication)
CLERK_JWKS_URL=https://<your-clerk-domain>.clerk.accounts.dev/.well-known/jwks.json
CLERK_ISSUER=https://<your-clerk-domain>.clerk.accounts.dev

# SQS — get from: cd terraform/6_agents && terraform output
SQS_QUEUE_URL=https://sqs.<region>.amazonaws.com/<account-id>/nestor-analysis-jobs

# API Gateway — get from: cd terraform/7_frontend && terraform output
NESTOR_API_GATEWAY_URL=https://<api-id>.execute-api.<region>.amazonaws.com

# Frontend
FRONTEND_URL=http://localhost:3000
CLOUDFRONT_URL=https://<distribution-id>.cloudfront.net
