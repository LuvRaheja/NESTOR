# Clerk Authentication — get keys from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_<your-clerk-publishable-key>
CLERK_SECRET_KEY=sk_test_<your-clerk-secret-key>

# Sign-in/up redirects
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# API URL
# For local Java API:            http://localhost:8080
# For deployed NESTOR API:       https://<api-id>.execute-api.<region>.amazonaws.com
# For CloudFront (production):   leave empty (relative paths)
NEXT_PUBLIC_API_URL=http://localhost:8080
